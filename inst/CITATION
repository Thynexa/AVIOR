citHeader("To cite avior in publications and validation reports, use:")

## Derive the cited version from the installed package metadata so the
## citation always reports the version that produced the evidence.
ver <- if (!is.null(meta$Version)) meta$Version else "development version"
note <- sprintf("R package version %s", ver)

bibentry(
  bibtype  = "Manual",
  title    = "{avior}: Validation Evidence Compiler for R Package Environments",
  author   = person("Thynexa", "Team"),
  year     = "2026",
  note     = note,
  url      = "https://github.com/Thynexa/AVIOR",
  textVersion = sprintf(
    paste(
      "Thynexa Team (2026).",
      "avior: Validation Evidence Compiler for R Package Environments.",
      "%s. https://github.com/Thynexa/AVIOR"
    ),
    note
  )
)
